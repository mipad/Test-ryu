<Project>
  <PropertyGroup>
    <ManagePackageVersionsCentrally>true</ManagePackageVersionsCentrally>
    <RestoreSources>https://api.nuget.org/v3/index.json</RestoreSources>
  </PropertyGroup>

  <ItemGroup>
    <!-- ====================== -->
    <!--     核心框架依赖       -->
    <!-- ====================== -->
    <PackageVersion Include="System.Text.Json" Version="8.0.2" />
    <PackageVersion Include="System.IO.Hashing" Version="8.0.0" />
    <PackageVersion Include="System.Management" Version="8.0.0" />
    <PackageVersion Include="System.Text.Encoding" Version="4.3.0" />

    <!-- ====================== -->
    <!--     显式声明缺失包     -->
    <!-- ====================== -->
    <PackageVersion Include="LibHac" Version="0.19.0" />
    <PackageVersion Include="MsgPack.Cli" Version="1.0.1" />
    <PackageVersion Include="Concentus" Version="2.2.2" />

    <!-- ====================== -->
    <!--     图形/多媒体库      -->
    <!-- ====================== -->
    <PackageVersion Include="OpenTK" Version="5.0.0-pre.13" />
    <PackageVersion Include="OpenTK.Core" Version="5.0.0-pre.13" />
    <PackageVersion Include="OpenTK.Graphics" Version="5.0.0-pre.13" />
    <PackageVersion Include="OpenTK.Audio.OpenAL" Version="5.0.0-pre.13" />
    <PackageVersion Include="OpenTK.Windowing.GraphicsLibraryFramework" Version="5.0.0" />

    <PackageVersion Include="Silk.NET.Vulkan" Version="2.22.0" />
    <PackageVersion Include="Silk.NET.Vulkan.Extensions.EXT" Version="2.22.0" />
    <PackageVersion Include="Silk.NET.Vulkan.Extensions.KHR" Version="2.22.0" />

    <PackageVersion Include="SkiaSharp" Version="3.119.0-preview.1.2" />
    <PackageVersion Include="SkiaSharp.NativeAssets.Linux" Version="3.119.0-preview.1.2" />

    <!-- ====================== -->
    <!--     Ryujinx 专用依赖   -->
    <!-- ====================== -->
    <PackageVersion Include="Ryujinx.Audio.OpenAL.Dependencies" Version="1.21.0.1" />
    <PackageVersion Include="Ryujinx.Graphics.Nvdec.Dependencies" Version="5.0.3" />
    <PackageVersion Include="Ryujinx.Graphics.Vulkan.Dependencies.MoltenVK" Version="1.2.0" />
    <PackageVersion Include="Ryujinx.SDL2-CS" Version="2.30.0-build32" />

    <!-- ====================== -->
    <!--     工具/辅助库       -->
    <!-- ====================== -->
    <PackageVersion Include="SharpZipLib" Version="1.4.7" />
    <PackageVersion Include="MessagePack" Version="2.4.59" /> <!-- 新序列化库 -->

    <PackageVersion Include="NetCoreServer" Version="8.0.7" />

    <PackageVersion Include="Microsoft.IO.RecyclableMemoryStream" Version="3.0.1" />
    <PackageVersion Include="DiscordRichPresence" Version="1.2.1.24" />

    <!-- ====================== -->
    <!--     安全关键依赖      -->
    <!-- ====================== -->
    <PackageVersion Include="Microsoft.IdentityModel.JsonWebTokens" Version="7.5.1" />
    <PackageVersion Include="securifybv.ShellLink" Version="0.1.0" />

    <!-- ====================== -->
    <!--     开发工具链       -->
    <!-- ====================== -->
    <PackageVersion Include="Microsoft.CodeAnalysis.Analyzers" Version="3.3.4" />
    <PackageVersion Include="Microsoft.CodeAnalysis.CSharp" Version="4.9.2" />

    <PackageVersion Include="Microsoft.NET.Test.Sdk" Version="17.14.0" />
    <PackageVersion Include="NUnit" Version="3.13.3" />
    <PackageVersion Include="NUnit3TestAdapter" Version="4.1.0" />

    <!-- ====================== -->
    <!--     特殊依赖         -->
    <!-- ====================== -->
    <PackageVersion Include="UnicornEngine.Unicorn" Version="2.1.3" />
    <PackageVersion Include="Rxmxnx.PInvoke.Extensions" Version="2.2.6" />
    <PackageVersion Include="shaderc.net" Version="0.1.0" />
    <PackageVersion Include="SPB" Version="0.0.4-build32" />
  </ItemGroup>

  <!-- ====================== -->
  <!--   强制覆盖策略        -->
  <!-- ====================== -->
  <ItemGroup>
    <!-- 统一 OpenTK 版本 -->
    <PackageVersion Update="OpenTK.*" Version="5.0.0-pre.13" OverwritePackagesVersion="true" />

    <!-- 强制指定关键包版本 -->
    <PackageVersion Update="LibHac" Version="0.19.0" />
    <PackageVersion Update="MsgPack.Cli" Version="1.0.1" />
    <PackageVersion Update="Concentus" Version="2.2.2" />
    <PackageVersion Update="Rxmxnx.PInvoke.Extensions" Version="2.2.6" />
    <PackageVersion Update="Silk.NET.Vulkan.Extensions.KHR" Version="2.22.0" />
  </ItemGroup>
</Project>
