<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>net9.0</TargetFramework>
    <EnablePreviewFeatures>True</EnablePreviewFeatures>
    <LangVersion>preview</LangVersion>
    <RuntimeIdentifiers>android-arm64;linux-bionic-arm64</RuntimeIdentifiers>
    <Nullable>enable</Nullable>
    <WarningsNotAsErrors>NU1901;NU1902;NU1903;NU1904</WarningsNotAsErrors>
    <NuGetAudit>false</NuGetAudit>
    <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
    <InvariantGlobalization>true</InvariantGlobalization>
    
    <!-- AOT 优化参数 -->
    <IlcGenerateMapFile>true</IlcGenerateMapFile>
    <IlcDisableUnhandledExceptionExperience>true</IlcDisableUnhandledExceptionExperience>
    <IlcGenerateCompleteTypeMetadata>true</IlcGenerateCompleteTypeMetadata>
    <IlcDisableReflection>false</IlcDisableReflection>
    <IlcTrimMetadata>true</IlcTrimMetadata>
  </PropertyGroup>

  <!-- Android 平台配置 -->
  <PropertyGroup Condition="'$(RuntimeIdentifier)'=='android-arm64'">
    <LinkerFlavor>lld</LinkerFlavor>
    <NativeLib>Shared</NativeLib>
    <IlcInstructionSet>armv8.2-a</IlcInstructionSet>
    <PublishAot>true</PublishAot>
    <StripSymbols>true</StripSymbols>
    <AndroidNativeLibrary>libryujinx.so</AndroidNativeLibrary>
  </PropertyGroup>

  <!-- Linux Bionic 配置 -->
  <PropertyGroup Condition="'$(RuntimeIdentifier)'=='linux-bionic-arm64'">
    <IlcInstructionSet>armv8-a</IlcInstructionSet>
    <StripSymbols>true</StripSymbols>
  </PropertyGroup>

  <!-- 合并链接参数 -->
  <ItemGroup>
    <LinkerArg 
      Condition="'$(RuntimeIdentifier)'=='android-arm64' OR '$(RuntimeIdentifier)'=='linux-bionic-arm64'"
      Include="-llog -ldl -lz -lm -lc" 
    />
  </ItemGroup>

  <!-- NuGet 包引用（无版本号） -->
  <ItemGroup>
    <PackageReference Include="Microsoft.DotNet.ILCompiler" />  <!-- 版本由 Directory.Packages.props 控制 -->
    <PackageReference Include="System.Text.Encoding" />
    <PackageReference Include="System.Text.Json" />
    <PackageReference Include="Rxmxnx.PInvoke.Extensions" />
    <PackageReference Include="Silk.NET.Vulkan" />
    <PackageReference Include="Silk.NET.Vulkan.Extensions.KHR" />
    <PackageReference Include="LibHac" />
  </ItemGroup>

  <!-- 显式定义 Android 工程路径 -->
  <PropertyGroup>
    <AndroidProjectDirectory>../RyujinxAndroid</AndroidProjectDirectory>
  </PropertyGroup>

  <!-- 构建后处理 -->
  <Target Name="PostBuildAndroid" AfterTargets="Publish" Condition="'$(RuntimeIdentifier)'=='android-arm64'">
    <Copy 
      SourceFiles="$(OutputPath)/*.so" 
      DestinationFolder="$(AndroidProjectDirectory)/app/src/main/jniLibs/arm64-v8a" 
    />
  </Target>
</Project>
