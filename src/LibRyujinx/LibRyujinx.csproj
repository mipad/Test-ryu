<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>net9.0</TargetFramework>
    <EnablePreviewFeatures>True</EnablePreviewFeatures>
    <LangVersion>preview</LangVersion>
    <RuntimeIdentifiers>linux-bionic-arm64</RuntimeIdentifiers>
    <Nullable>enable</Nullable>
    <WarningsNotAsErrors>NU1901;NU1902;NU1903;NU1904</WarningsNotAsErrors>
    <NuGetAudit>false</NuGetAudit>
    <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
    <InvariantGlobalization>true</InvariantGlobalization>
    
    <!-- AOT 优化参数 -->
    <IlcGenerateMapFile>true</IlcGenerateMapFile>
    <IlcDisableUnhandledExceptionExperience>true</IlcDisableUnhandledExceptionExperience>
    <IlcGenerateCompleteTypeMetadata>true</IlcGenerateCompleteTypeMetadata>
    <IlcDisableReflection>false</IlcDisableReflection>
    <IlcTrimMetadata>true</IlcTrimMetadata>
  </PropertyGroup>

  <!-- Linux Bionic 配置 -->
  <PropertyGroup Condition="'$(RuntimeIdentifier)'=='linux-bionic-arm64'">
    <IlcInstructionSet>armv8-a</IlcInstructionSet>
    <StripSymbols>true</StripSymbols>
  </PropertyGroup>

  <!-- 链接参数 -->
  <ItemGroup>
    <LinkerArg Condition="'$(RuntimeIdentifier)'=='linux-bionic-arm64'" Include="-llog" />
    <LinkerArg Condition="'$(RuntimeIdentifier)'=='linux-bionic-arm64'" Include="-ldl" />
    <LinkerArg Condition="'$(RuntimeIdentifier)'=='linux-bionic-arm64'" Include="-lz" />
    <LinkerArg Condition="'$(RuntimeIdentifier)'=='linux-bionic-arm64'" Include="-lm" />
    <LinkerArg Condition="'$(RuntimeIdentifier)'=='linux-bionic-arm64'" Include="-lc" />
  </ItemGroup>

  <!-- NuGet 包引用 -->
  <ItemGroup>
    <PackageReference Include="Microsoft.DotNet.ILCompiler" />
    <PackageReference Include="System.Text.Encoding" />
    <PackageReference Include="System.Text.Json" />
    <PackageReference Include="Rxmxnx.PInvoke.Extensions" />
    <PackageReference Include="Silk.NET.Vulkan" />
    <PackageReference Include="Silk.NET.Vulkan.Extensions.KHR" />
    <PackageReference Include="LibHac" />
  </ItemGroup>
</Project>
